{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "native-gb-tetris-modern: configure dev",
      "type": "process",
      "command": "cmake",
      "args": ["--preset", "dev"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$gcc", "$msCompile"]
    },
    {
      "label": "native-gb-tetris-modern: build dev",
      "type": "process",
      "command": "cmake",
      "args": ["--build", "--preset", "dev", "--parallel"],
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": ["native-gb-tetris-modern: configure dev"],
      "dependsOrder": "sequence",
      "problemMatcher": ["$gcc", "$msCompile"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
